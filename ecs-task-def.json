{
  "family": "apex-backend-staging",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "containerDefinitions": [
    {
      "name": "apex-backend-staging",
      "image": "381492233160.dkr.ecr.us-east-1.amazonaws.com/apex-backend-staging:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "SUPABASE_URL",
          "value": "YOUR_SUPABASE_URL"
        },
        {
          "name": "SUPABASE_ANON_KEY",
          "value": "YOUR_SUPABASE_ANON_KEY"
        },
        {
          "name": "AWS_ACCESS_KEY_ID",
          "value": "YOUR_AWS_ACCESS_KEY_ID"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "value": "YOUR_AWS_SECRET_ACCESS_KEY"
        },
        {
          "name": "AWS_REGION",
          "value": "us-east-1"
        },
        {
          "name": "S3_BUCKET_NAME",
          "value": "intermediate-apex-bucket-east"
        },
        {
          "name": "CORS_ORIGINS",
          "value": "http://localhost:3000,http://localhost:3001,https://apexdevx.intermediateds.co.za,https://apex.intermediateds.co.za"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/apex-backend-staging",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "executionRoleArn": "arn:aws:iam::381492233160:role/ecsTaskExecutionRole"
}
