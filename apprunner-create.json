{
  "ServiceName": "apex-backend",
  "SourceConfiguration": {
    "ImageRepository": {
      "ImageIdentifier": "381492233160.dkr.ecr.us-east-1.amazonaws.com/apex-backend:latest",
      "ImageRepositoryType": "ECR",
      "ImageConfiguration": {
        "Port": "8000",
        "RuntimeEnvironmentVariables": {
          "SUPABASE_URL": "YOUR_SUPABASE_URL",
          "SUPABASE_ANON_KEY": "YOUR_SUPABASE_ANON_KEY",
          "AWS_ACCESS_KEY_ID": "YOUR_AWS_ACCESS_KEY_ID",
          "AWS_SECRET_ACCESS_KEY": "YOUR_AWS_SECRET_ACCESS_KEY",
          "AWS_REGION": "us-east-1",
          "S3_BUCKET_NAME": "intermediate-apex-bucket-east",
          "CORS_ORIGINS": "https://apexdevx.intermediateds.co.za,https://apex.intermediateds.co.za"
        }
      }
    },
    "AutoDeploymentsEnabled": true,
    "AuthenticationConfiguration": {
      "AccessRoleArn": "arn:aws:iam::381492233160:role/AppRunnerApexBackendRole"
    }
  },
  "InstanceConfiguration": {
    "Cpu": "1024",
    "Memory": "2048",
    "InstanceRoleArn": "arn:aws:iam::381492233160:role/AppRunnerApexBackendRole"
  }
}
